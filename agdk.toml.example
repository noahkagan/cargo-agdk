# Example agdk.toml. Place this file at your workspace root and
# `cargo agdk <subcommand>` will discover it by walking up from cwd.
# Override the discovery with `--config <path>`.

# Public GitHub repo hosting the toolchain bundle's releases. Must be
# public so verify-side sandboxes can fetch without auth. REQUIRED.
release-host = "acme/android-toolchain"

# Lock file path (relative to workspace root). Defaults to
# "android/toolchain.lock". cargo-agdk reads it on verify/install and
# writes it on package.
lockfile = "android/toolchain.lock"

# The Gradle Android project root (relative to workspace root).
# `verify` runs ./gradlew from here. The jniLibs and APK output paths
# derive from this:
#   - jniLibs:    <android-project>/app/src/<flavor>/jniLibs
#   - APK output: <android-project>/app/build/outputs/apk/<flavor>/debug/app-<flavor>-debug.apk
# (Both follow AGP's standard project layout.)
android-project = "android"

# Path to AGP version pin (workspace-root-relative). cargo-agdk reads
# `agp = "X"` from this file — AGP's standard `libs.versions.toml`
# catalog format.
agp-file = "android/gradle/libs.versions.toml"

# Path to NDK version pin (workspace-root-relative). cargo-agdk reads
# the file's whole content, trimmed, as the version.
ndk-file = "android/ndk.version"

# Path to Gradle distribution pin (workspace-root-relative).
# cargo-agdk extracts the version from
# `distributionUrl=...gradle-X-bin.zip`.
gradle-file = "android/gradle/wrapper/gradle-wrapper.properties"

# Each [[target]] is one thing you can verify-build.
# `cargo agdk verify <name>` looks up by `name`. REQUIRED, at least 1.
[[target]]
name    = "example"
package = "example-game"        # cargo package: `cargo build -p <this>`
flavor  = "exampleGame"         # gradle flavor: ./gradlew assemble<Capitalized>Debug
cdylib  = "example_game_lib"    # cdylib name: jniLibs/.../lib<this>.so
